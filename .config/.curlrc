# cURL configuration options
# http://curl.haxx.se/docs/manpage.html

# Output newline on stdout after a completed transfer
--write-out= "\n"

# Resume a previous file transfer at the given offset
--continue-at -

# Limit the time (in seconds) the connection is allowed to take
--connect-timeout 60

# Compress the response
--compressed

# Follow  redirects
--location

# Display progress as a simple progress bar
--progress-bar

# When following a redirect, automatically set the previous URL as referer.
--referer ";auto"

# Display HTTP headers in bold
--styled-output

# Show error messages
--show-error

# Send a fake UA for the HTTP servers that sniff it
--user-agent "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/106.0.0.0 Safari/537.36 Edg/105.0.1343.53"

# Extra headers to include in the request
--header "Upgrade-Insecure-Requests: 1"
--header "Accept-Language: en-US,en;q=0.8"
